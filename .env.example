# ─────────────────────────────────────────────────────────────
# Aiza Quran Academy — Frontend Environment Variables
# Hostinger Node.js panel mein ye sab "Environment Variables"
# section mein add karein (KEY = VALUE format)
# ─────────────────────────────────────────────────────────────

# Backend API ka full URL (trailing slash mat lagayein)
NEXT_PUBLIC_API_URL=https://api.aizaquranacademy.com

# Node environment
NODE_ENV=production
