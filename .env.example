# Copy to `.env.local` (dev) or set in Hostinger before `npm run build`:
# NEXT_PUBLIC_* is inlined at build time — redeploy frontend after changing this.

# Your Node/backend URL from Hostinger (HTTPS, no trailing slash), e.g.:
# NEXT_PUBLIC_API_URL=https://darkturquoise-pigeon-295230.hostingersite.com
NEXT_PUBLIC_API_URL=https://YOUR-BACKEND-SUBDOMAIN.hostingersite.com
